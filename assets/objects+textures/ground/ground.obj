mtllib ground.mtl

o Ground

# top (2000 x 2000)
v -1000.0 0.0 -1000.0
v  1000.0 0.0 -1000.0
v  1000.0 0.0  1000.0
v -1000.0 0.0  1000.0

# bottom (thickness = 5)
v -1000.0 -5.0 -1000.0
v  1000.0 -5.0 -1000.0
v  1000.0 -5.0  1000.0
v -1000.0 -5.0  1000.0

vn 0.0 1.0 0.0
vn 0.0 -1.0 0.0
vn 0.0 0.0 1.0
vn 0.0 0.0 -1.0
vn 1.0 0.0 0.0
vn -1.0 0.0 0.0

usemtl Green

# top
f 1//1 2//1 3//1
f 1//1 3//1 4//1

# bottom
f 5//2 8//2 7//2
f 5//2 7//2 6//2

# sides
f 4//3 3//3 7//3
f 4//3 7//3 8//3

f 1//4 5//4 6//4
f 1//4 6//4 2//4

f 2//5 6//5 7//5
f 2//5 7//5 3//5

f 1//6 4//6 8//6
