# large_ground.obj

mtllib floor.mtl
usemtl GroundMaterial

o Ground

# top vertices
v -500.0 0.0 -500.0
v  500.0 0.0 -500.0
v  500.0 0.0  500.0
v -500.0 0.0  500.0

# bottom vertices
v -500.0 -50.0 -500.0
v  500.0 -50.0 -500.0
v  500.0 -50.0  500.0
v -500.0 -50.0  500.0

# top UVs (tiled)
vt 0.0 0.0
vt 10.0 0.0
vt 10.0 10.0
vt 0.0 10.0

# side UVs (each face gets its own)
vt 0.0 0.0  #5
vt 1.0 0.0  #6
vt 1.0 5.0  #7
vt 0.0 5.0  #8

vt 0.0 0.0  #9
vt 1.0 0.0  #10
vt 1.0 5.0  #11
vt 0.0 5.0  #12

vt 0.0 0.0  #13
vt 1.0 0.0  #14
vt 1.0 5.0  #15
vt 0.0 5.0  #16

vt 0.0 0.0  #17
vt 1.0 0.0  #18
vt 1.0 5.0  #19
vt 0.0 5.0  #20

# top
f 1/1 2/2 3/3
f 1/1 3/3 4/4

# bottom
f 5/1 7/3 6/2
f 5/1 8/4 7/3

# front
f 1/5 5/6 6/7
f 1/5 6/7 2/8

# right
f 2/9 6/10 7/11
f 2/9 7/11 3/12

# back
f 3/13 7/14 8/15
f 3/13 8/15 4/16

# left
f 4/17 8/18 5/19
f 4/17 5/19 1/20
